<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/PageBg1"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/title_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/login_title"
                android:textColor="@color/text_fit_theme"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/subtitle_label"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/subtitle_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/login_subtitle"
                android:textColor="@color/check_description_color"
                android:textSize="16sp"
                app:layout_constraintBottom_toTopOf="@+id/login_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title_label" />

            <FrameLayout
                android:id="@+id/login_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="40dp"
                app:layout_constraintTop_toBottomOf="@+id/subtitle_label">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/login_phone_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible">

                    <com.hchen.himiuix.widget.MiuixEditText
                        android:id="@+id/phone_text_field"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:background="@drawable/miuix_edit_background"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawablePadding="12dp"
                        android:hint="@string/login_phone_hint"
                        android:inputType="phone"
                        android:maxLength="11"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_fit_theme"
                        android:textColorHint="@color/miuix_summary_color"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.hchen.himiuix.widget.MiuixEditText
                        android:id="@+id/code_text_field"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/miuix_edit_background"
                        android:drawableStart="@drawable/ic_security"
                        android:drawablePadding="12dp"
                        android:hint="@string/login_code_hint"
                        android:inputType="number"
                        android:maxLength="6"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_fit_theme"
                        android:textColorHint="@color/miuix_summary_color"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@+id/get_code_button"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/phone_text_field" />

                    <Button
                        android:id="@+id/get_code_button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:background="@drawable/miuix_dialog_button_2"
                        android:text="@string/login_get_code"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="@+id/code_text_field"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/code_text_field"
                        app:layout_constraintTop_toTopOf="@+id/code_text_field"
                        app:layout_constraintWidth_max="140dp" />

                    <Button
                        android:id="@+id/login_button"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="32dp"
                        android:background="@drawable/miuix_dialog_button_2"
                        android:text="@string/login_button"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/code_text_field" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <Button
                    android:id="@+id/weixin_login_container_first"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/miuix_dialog_button_2"
                    android:drawableStart="@drawable/ic_weixin_btn"
                    android:drawablePadding="8dp"
                    android:gravity="center"
                    android:text="微信一键登录"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/privacy_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/login_container">

                <com.hchen.himiuix.widget.MiuixCheckBox
                    android:id="@+id/privacy_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/privacy_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:lineSpacingExtra="2dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="同意《隐私协议和用户协议》"
                    android:textColor="@color/text_fit_theme"
                    android:textSize="14sp" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/thrid_login_divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/privacy_container">

                <View
                    android:id="@+id/divider_left"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.3"
                    android:background="@color/check_description_color"
                    app:layout_constraintBottom_toBottomOf="@+id/other_login_label"
                    app:layout_constraintEnd_toStartOf="@+id/other_login_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/other_login_label" />

                <TextView
                    android:id="@+id/other_login_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="32dp"
                    android:text="其他登录方式"
                    android:textColor="@color/check_description_color"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/divider_right"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="32dp"
                    android:alpha="0.3"
                    android:background="@color/check_description_color"
                    app:layout_constraintBottom_toBottomOf="@+id/other_login_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/other_login_label"
                    app:layout_constraintTop_toTopOf="@+id/other_login_label" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/thrid_login_divider">

                <LinearLayout
                    android:id="@+id/weixin_login_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="18dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/weixin_login_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_weixin" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/weixin_login_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="微信登录"
                        android:textColor="@color/text_fit_theme"
                        android:textSize="13sp" />

                </LinearLayout>

                <Button
                    android:id="@+id/phone_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/miuix_dialog_button_1"
                    android:paddingStart="24dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="12dp"
                    android:text="使用手机号登录"
                    android:textColor="@color/miuix_dialog_button_2"
                    android:textSize="16sp"
                    android:visibility="visible" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/copyright_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="@string/login_copyright"
            android:textColor="@color/check_description_color"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </LinearLayout>
</ScrollView>
