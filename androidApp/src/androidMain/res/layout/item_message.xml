<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/miuix_item_ripple"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="12dp"
    android:paddingEnd="12dp">

    <CheckBox
        android:id="@+id/select_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/message_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/message_title"
        tools:visibility="visible" />

    <View
        android:id="@+id/unread_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/unread_dot_background"
        android:visibility="visible"
        app:layout_constraintStart_toEndOf="@+id/select_checkbox"
        app:layout_constraintTop_toTopOf="@+id/message_title"
        app:layout_constraintVertical_bias="0.3" />

    <TextView
        android:id="@+id/message_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:textColor="@color/miuix_title_color"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/link_icon"
        app:layout_constraintStart_toEndOf="@+id/unread_dot"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="消息标题消息标题消息标题消息标题消息标题消息标题消息标题消息标题消息标题" />

    <ImageView
        android:id="@+id/link_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="来源链接"
        android:focusable="true"
        android:src="@drawable/ic_link"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/message_title"
        app:tint="@color/miuix_summary_color"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/source_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="来源: 未知"
        android:textColor="@color/miuix_summary_color"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/date_label"
        app:layout_constraintStart_toStartOf="@+id/message_title"
        app:layout_constraintTop_toBottomOf="@+id/message_title" />

    <TextView
        android:id="@+id/date_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="12:30"
        android:textColor="@color/miuix_summary_color"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/source_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/source_label" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:alpha="0.2"
        android:background="@color/miuix_summary_color"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/source_label" />

</androidx.constraintlayout.widget.ConstraintLayout>
